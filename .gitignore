# dependencies
node_modules/
.pnpm-store/

# build outputs
dist/
*.tsbuildinfo

# test / e2e
coverage/
test-results/
playwright-report/
.playwright/

# generated fixtures (large signed sample packs, regenerated by `pnpm fixtures`)
fixtures/generated/
packages/app/public/fixtures/

# dev secrets (Ed25519 signing keys — never commit private key)
keys/*.private

# local env (gateway token, broker URLs, any VITE_* secret) — never commit real values; keep templates
.env
.env.*
!.env.example
!*/.env.example

# turbo
.turbo/

# local dev tools (arduino-cli + avr core used only to generate committed fixtures)
.tools/

# os
.DS_Store
**/.DS_Store

# logs
*.log
ci/toolchain-builder/out/
packages/app/public/toolchain/
packages/app/public/c3-toolchain/
packages/app/public/esp32-classic-toolchain/
ci/toolchain-builder/esp32/build/
ci/toolchain-builder/esp32-classic/build/
