# Sparklab Tier-3 gateway config. Copy to `.env`. Defaults are SECURE (default-deny).

# Port the WebSocket relay listens on (put a TLS reverse proxy in front for wss:// — see README).
GATEWAY_PORT=9000

# REQUIRED for any real use. Comma-separated host allowlist (default-deny — empty reaches NOTHING).
# Exact names or *.suffix wildcards. List only the brokers/APIs you teach with.
GATEWAY_ALLOWLIST=broker.emqx.io,*.hivemq.com,test.mosquitto.org

# REQUIRED before exposing publicly. Clients must connect with ?token=<this>.
GATEWAY_TOKEN=change-me-to-a-long-random-secret

# Egress hardening — leave ON (set to 1 ONLY for a trusted local test).
# GATEWAY_ALLOW_PRIVATE=1   # ⚠ disables private/metadata-IP blocking — DANGEROUS, never in production

# Per-session caps.
GATEWAY_MAX_CONNS=8
GATEWAY_CONN_RATE=5
GATEWAY_BANDWIDTH=1000000
GATEWAY_SESSION_SECONDS=600
